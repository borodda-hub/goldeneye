# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://ngti:ngti@localhost:5432/ngti
# Force TLS on the DB connection (managed Postgres like Timescale Cloud needs
# it). Leave false locally. You can also just paste the provider's URL with
# `?sslmode=require` — it's detected and normalized automatically.
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM
ANTHROPIC_API_KEY=

# External data sources (leave blank to use mock adapters)
EIA_API_KEY=
CFTC_DATA_URL=https://www.cftc.gov/files/dea/history/fut_disagg_txt_2024.zip
NWS_API_BASE=https://api.weather.gov

# Adapter selection: "mock" (default) or "real"
ADAPTER_MARKET=mock
ADAPTER_ENERGY=mock
ADAPTER_WEATHER=mock
ADAPTER_POSITIONING=mock
ADAPTER_NEWS=mock

# App config
LOG_LEVEL=INFO
SENTRY_DSN=

# Browser origins allowed to call this API (comma-separated). Defaults cover
# local dev. In prod, set to your deployed web origin, e.g.:
#   CORS_ALLOWED_ORIGINS=https://goldeneye.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
