# FastAPI backend base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket base URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Accounts (Clerk) — OPTIONAL ──────────────────────────────────────────────
# Leave blank to run fully open/anonymous (the demo + local dev work untouched).
# Set both keys (free at https://dashboard.clerk.com) to enable sign-up:
#   - the user's email + signup/active counts appear in the Clerk dashboard
#   - signed-in users' work persists to their account
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
